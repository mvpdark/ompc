# ============================================================
# OMPC Shell Configuration
# OMPC is a web framework shell - NO API keys needed here.
# API keys belong in OMPC-SSB and OMPC-ZSCJ containers.
# Copy this file to .env and adjust values as needed.
# ============================================================

# --- Runtime ---
RUNTIME_PROFILE=desktop

# --- Database ---
# SQLite for local development:
DATABASE_URL=sqlite:///./artifacts/dev/opc-dev.db
# Self-hosted PostgreSQL alternative:
# RUNTIME_PROFILE=self_hosted
# DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/opc
DATABASE_CONNECT_TIMEOUT_SECONDS=2

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Authentication / JWT ---
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
AUTH_REQUIRED=true

# --- Frontend / CORS ---
FRONTEND_ORIGIN=http://localhost:60000
# CORS_ORIGIN_REGEX=  # Optional. When unset, CORS origins are derived from FRONTEND_ORIGIN.

# --- ZSCJ integration ---
ZSCJ_API_BASE_URL=http://localhost:60002/api/v1
